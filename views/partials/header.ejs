<!DOCTYPE html>
<html lang="en-US">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
  <meta name="description" content="TruckRiser" />
  <meta name="author" content="W-code81" />
  <link rel="shortcut icon" href="Image/download.jpeg" type="image/x-icon" />

  <!-- fontawesome -->
  <link rel="stylesheet" href="/css/all.min.css" />

  <!-- bootstrap CSS (CDN) -->
  <!-- <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /> -->

  <!-- main styling -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- page-specific CSS -->
  <% if (typeof currentPage !== 'undefined') { %>
    <% if (currentPage === 'signup') { %>
      <link rel="stylesheet" href="/css/signup.css" />
    <% } else if (currentPage === 'login') { %>
      <link rel="stylesheet" href="/css/login.css" />
    <% } else if (currentPage === 'pricing') { %>
      <link rel="stylesheet" href="/css/pricing.css" />
    <% } %>
  <% } %>
  
  <!-- bootstrap JS (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

  <% if (error && error.length > 0) { %>
<div class="alert alert-danger alert-dismissible fade show error" role="alert" id="errorAlert">
  <%= error[0] %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<% if (success && success.length > 0) { %>
<div class="alert alert-success alert-dismissible fade show success" role="alert" id="successAlert">
  <%= success[0] %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

