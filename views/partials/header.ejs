<!DOCTYPE html>
<html lang="en-US">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
  <meta name="description" content="TruckRiser" />
  <meta name="author" content="W-code81" />
  <link rel="shortcut icon" href="Image/download.jpeg" type="image/x-icon" />

  <!-- Font Awesome CDN (fallback to local file if you prefer) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />


  <!-- main styling -->
  <link rel="stylesheet" href="/css/style.css" />

  <!-- page-specific CSS -->
  <% if (typeof currentPage !== 'undefined') { %>
    <% if (currentPage === 'signup') { %>
      <link rel="stylesheet" href="/css/signup.css" />
    <% } else if (currentPage === 'login') { %>
      <link rel="stylesheet" href="/css/login.css" />
    <% } else if (currentPage === 'pricing') { %>
      <link rel="stylesheet" href="/css/pricing.css" />
    <% } %>
  <% } %>
  
  <!-- bootstrap JS (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body>

  <% if (error && error.length > 0) { %>
<div class="flash flash-error" id="errorAlert">
  <span class="flash-icon"></span>
  <span class="flash-text"><%= error[0] %></span>
  <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
</div>
<% } %>

<% if (success && success.length > 0) { %>
<div class="flash flash-success" id="successAlert">
  <span class="flash-icon"></span>
  <span class="flash-text"><%= success[0] %></span>
  <button class="flash-close" onclick="this.parentElement.remove()">✕</button>
</div>
<% } %>

