<% if (!cookieConsent && showCookieBanner) { %>
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-live="polite" aria-label="Cookie banner">
  <div class="cookie-inner">
    <div class="cookie-text">
      <div>
        <strong>We use cookies</strong>
        <div class="cookie-desc">to enhance your experience and analyze traffic. By clicking <strong>Accept</strong>, you agree to our <a href="/privacy">Privacy Policy</a>.</div>
      </div>
    </div>

    <div class="cookie-actions">
      <button id="accept-cookies-btn" class="cookie-btn cookie-btn-primary">Accept</button>
      <button id="manage-cookies-btn" class="cookie-btn cookie-btn-secondary">Manage</button>
    </div>
  </div>
</div>
<% } %>
<script src="https://unpkg.com/scrollreveal"></script>
<script src="js/script.js"></script>

</body>

</html>