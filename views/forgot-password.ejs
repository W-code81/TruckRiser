<%- include("./partials/header.ejs") %>

<div class="page-signup">
  <div class="form-container">
    <form action="/forgot-password" method="POST" id="forgotForm">
      <h1>Forgot Password ?</h1>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <p class="form-sub">Enter the email address linked to your account and we'll send you a reset link.</p>

      <label for="email">Email:</label>
      <input type="email" id="email" placeholder="Email" name="email" required />

      <button class="login" type="submit"> Send Link</button>

      <a href="/login" class="signup-link">Back to Login</a>
    </form>
  </div>
</div>

<script src="/js/auth.js"></script>
<%- include("./partials/footer.ejs") %>