<%- include("./partials/header.ejs") %>

<div class="page-signup">
  <div class="form-container">
    <form action="/reset-password/<%= token %>" method="POST" id="resetForm">
      <h1>New Password🔒</h1>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <p class="form-sub">Enter a new password for your account. It must be at least 8 characters long.</p>

      <label for="password">New Password:</label>
      <div class="password-container">
        <input type="password" id="password" placeholder="New Password" name="password" required />
        <span id="show-password"><i class="fas fa-eye"></i></span>
      </div>

      <label for="confirmPassword">Confirm Password:</label>
      <div class="password-container">
        <input type="password" id="confirmPassword" placeholder="Confirm Password" name="confirmPassword" required />
        <span id="show-confirm-password"><i class="fas fa-eye"></i></span>
      </div>

      <button class="login" type="submit">Reset</button>

      <a href="/login" class="signup-link">Back to Login</a>
    </form>
  </div>
</div>

<script src="/js/auth.js"></script>
<%- include("./partials/footer.ejs") %>